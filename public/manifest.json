{
  "manifest_version": 3,
  "name": "AsciiDoc Viewer",
  "version": "1.0.0",
  "description": "Preview AsciiDoc files with folder navigation, include:: support, and auto-refresh",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open AsciiDoc Viewer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*.adoc", "*://*/*.adoc?*",
        "*://*/*.asciidoc", "*://*/*.asciidoc?*",
        "*://*/*.asc", "*://*/*.asc?*",
        "*://*/*.ad", "*://*/*.ad?*",
        "*://*/*.adoc.txt", "*://*/*.adoc.txt?*",
        "file://*/*.adoc", "file://*/*.adoc?*",
        "file://*/*.asciidoc", "file://*/*.asciidoc?*",
        "file://*/*.asc", "file://*/*.asc?*",
        "file://*/*.ad", "file://*/*.ad?*",
        "file://*/*.adoc.txt", "file://*/*.adoc.txt?*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "*://*/*.adoc", "*://*/*.adoc?*",
    "*://*/*.asciidoc", "*://*/*.asciidoc?*",
    "*://*/*.asc", "*://*/*.asc?*",
    "*://*/*.ad", "*://*/*.ad?*",
    "*://*/*.adoc.txt", "*://*/*.adoc.txt?*",
    "file://*/*.adoc", "file://*/*.adoc?*",
    "file://*/*.asciidoc", "file://*/*.asciidoc?*",
    "file://*/*.asc", "file://*/*.asc?*",
    "file://*/*.ad", "file://*/*.ad?*",
    "file://*/*.adoc.txt", "file://*/*.adoc.txt?*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "index.html",
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
